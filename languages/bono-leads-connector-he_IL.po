#. Description of the plugin
#: bono-leads-connector.php
msgid "Captures WordPress form submissions and sends them to Bono."
msgstr "לוכד שליחות טפסים מוורדפרס ושולח אותן ל-Bono."

#. Author of the plugin
#: bono-leads-connector.php
msgid "Bono"
msgstr "Bono"

#: admin/settings-page.php:15
msgid "Connect this WordPress site to Bono and send form submissions as lead sources."
